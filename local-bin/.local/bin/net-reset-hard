#!/usr/bin/env bash
set -euo pipefail

log() {
    printf '[net-reset-hard] %s\n' "$*"
}

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        printf 'Missing command: %s\n' "$1" >&2
        exit 1
    }
}

sudo_run() {
    if command -v sudo >/dev/null 2>&1; then
        if [[ -n "${SUDO_ASKPASS:-}" ]]; then
            sudo -A "$@"
        else
            sudo "$@"
        fi
    else
        "$@"
    fi
}

kill_edge() {
    log "closing Edge related processes"
    pkill -f '/opt/microsoft/msedge/msedge' 2>/dev/null || true
    pkill -f 'msedge_crashpad_handler' 2>/dev/null || true
}

current_proxy_mode() {
    gsettings get org.gnome.system.proxy mode | tr -d "'"
}

restore_proxy_mode() {
    local mode="${1:-none}"
    log "restoring proxy mode: ${mode}"
    gsettings set org.gnome.system.proxy mode "$mode"
}

wait_for_connected() {
    local tries=0
    while (( tries < 20 )); do
        if nmcli -t -f DEVICE,TYPE,STATE,CONNECTION device | awk -F: '$2=="wifi" && $3 ~ /^connected/ {found=1} END {exit found?0:1}'; then
            return 0
        fi
        sleep 2
        tries=$((tries + 1))
    done
    return 1
}

reconnect_wifi() {
    local wifi_line wifi_dev wifi_conn

    wifi_line="$(nmcli -t -f DEVICE,TYPE,STATE,CONNECTION device | awk -F: '$2=="wifi" && ($3 ~ /^connected/ || $3=="disconnected") {print; exit}')"
    if [[ -z "${wifi_line}" ]]; then
        log "no wifi device found, skipping wifi reconnect"
        return 0
    fi

    IFS=: read -r wifi_dev _ _ wifi_conn <<< "${wifi_line}"
    if [[ -n "${wifi_conn}" ]]; then
        log "bringing wifi connection back up: ${wifi_conn}"
        nmcli connection up id "${wifi_conn}" || nmcli device connect "${wifi_dev}"
    else
        log "connecting wifi device: ${wifi_dev}"
        nmcli device connect "${wifi_dev}"
    fi
}

print_summary() {
    log "current network summary"
    nmcli -t -f DEVICE,TYPE,STATE,CONNECTION device
    printf '\n'
    gsettings get org.gnome.system.proxy mode
    printf '\n'
    sed -n '1,8p' /etc/resolv.conf
}

main() {
    local original_proxy_mode

    need_cmd pkill
    need_cmd nmcli
    need_cmd gsettings
    need_cmd systemctl

    original_proxy_mode="$(current_proxy_mode)"
    log "original proxy mode: ${original_proxy_mode}"

    kill_edge
    log "temporarily disabling desktop proxy"
    gsettings set org.gnome.system.proxy mode 'none'

    log "restarting clash-verge-service"
    sudo_run systemctl restart clash-verge-service

    log "restarting NetworkManager"
    sudo_run systemctl restart NetworkManager
    sleep 3

    reconnect_wifi
    if ! wait_for_connected; then
        log "wifi did not report connected state in time"
    fi

    restore_proxy_mode "${original_proxy_mode}"
    sleep 2
    print_summary
}

main "$@"
