#!/bin/bash

# 发送开始通知
notify-send "Yay 升级" "开始系统更新..." -u normal -t 3000

# 使用 expect 或直接监控，在需要密码时发送通知
(
    # 等待一段时间后检查 yay 进程状态
    sleep 2
    while pgrep -x yay > /dev/null; do
        # 检查是否有 sudo 在等待密码
        if pgrep -x sudo > /dev/null && ! pgrep -a sudo | grep -q "NOPASSWD"; then
            # 检查 sudo 是否在等待输入
            if ps aux | grep -E "sudo.*yay" | grep -v grep > /dev/null; then
                notify-send "需要输入密码" "Yay 正在等待你的 sudo 密码！" -u critical -t 10000
                # 只通知一次
                break
            fi
        fi
        sleep 1
    done
) &

# 执行实际的 yay 命令
/usr/bin/yay "$@"

# 保存退出状态
EXIT_CODE=$?

# 发送完成通知
if [ $EXIT_CODE -eq 0 ]; then
    notify-send "Yay 升级完成" "系统更新已完成" -u normal -t 5000
else
    notify-send "Yay 升级失败" "更新过程出错，退出码: $EXIT_CODE" -u critical -t 10000
fi

exit $EXIT_CODE
