# #######################################################################################
# Hyprland 配置文件 - 终极整合版
# 基于最新的 Hyprland 语法，并整合了您之前的个性化配置。
# #######################################################################################

# 查阅 Hyprland Wiki 获取所有可用选项的详细信息: https://wiki.hypr.land/Configuring/

# 您可以将配置拆分到多个文件中，像这样引入:
# source = ~/.config/hypr/myColors.conf

################
### 显示器设置 ###
################
# 'preferred' 表示首选分辨率, 'auto' 表示自动位置和刷新率
monitor=,preferred,auto,auto


###################
### 定义常用程序 ###
###################
# 设置您常用的程序变量，方便后续调用
$terminal = kitty
$fileManager = dolphin
# 您可以在 wofi 和 hyprlauncher 之间选择一个作为您的程序启动器
$menu = wofi --show drun
# $menu = hyprlauncher


#################
### 开机自启 ###
#################
# 在此处设置开机自启的必要进程 (如: 通知服务, 状态栏, 壁纸等)
# 以下项目移植自您之前的配置。
exec-once = mako                  # 通知守护进程
exec-once = fcitx5                # 中文输入法框架
exec-once = waybar &              # 状态栏 (使用 '&' 使其在后台运行)
exec-once = hyprpaper &           # 壁纸程序 (使用 '&' 使其在后台运行)
exec-once = wl-paste --watch cliphist store # 剪贴板历史记录工具


#############################
### 环境变量 ###
#############################
# 设置会话所需的环境变量, 如光标大小、输入法等
# 以下输入法相关变量移植自您之前的配置，对中文输入至关重要。
env = XCURSOR_SIZE,24
env = HYPRCURSOR_SIZE,24
env = XIM,fcitx
env = XIM_PROGRAM,fcitx
env = INPUT_METHOD,fcitx
env = GTK_IM_MODULE,fcitx
env = QT_IM_MODULE,fcitx
env = XMODIFIERS,@im=fcitx


###################
### 权限管理 ###
###################
# 这是 Hyprland 新版本中引入的安全特性。
# 除非您明确知道需要为某个程序授权 (如截图)，否则请保持注释状态。
# ecosystem {
#   enforce_permissions = 1
# }
# permission = /usr/(bin|local/bin)/grim, screencopy, allow


#####################
### 外观与感受 ###
#####################

# 通用设置
general {
    gaps_in = 5             # 窗口之间的间隙
    gaps_out = 20           # 窗口与屏幕边缘的间隙
    border_size = 2         # 窗口边框大小
    # 活跃窗口和非活跃窗口的边框颜色，支持渐变
    col.active_border = rgba(33ccffee) rgba(00ff99ee) 45deg
    col.inactive_border = rgba(595959aa)
    resize_on_border = false # 是否允许通过拖动边框来调整窗口大小
    allow_tearing = false   # 是否允许屏幕撕裂 (通常建议关闭)
    layout = dwindle        # 默认窗口布局
}

# 装饰
decoration {
    rounding = 10           # 窗口圆角大小
    # rounding_power = 2    # 此选项在新版中已弃用，现在的圆角是线性的

    # 活跃和非活跃窗口的透明度
    active_opacity = 1.0
    inactive_opacity = 1.0

    # 窗口阴影
    shadow {
        enabled = true
        range = 4
        render_power = 3
        color = rgba(1a1a1aee)
    }

    # 背景模糊效果 (毛玻璃)
    blur {
        enabled = true
        size = 3
        passes = 1
        vibrancy = 0.1696
    }
}

# 动画效果
animations {
    enabled = yes

    # 动画曲线 (贝塞尔曲线)
    bezier = easeOutQuint,   0.23, 1,    0.32, 1
    bezier = easeInOutCubic, 0.65, 0.05, 0.36, 1

    # 动画效果设置 (采用了一套更简洁、流畅的现代配置)
    animation = global,        1,     10,    default
    animation = border,        1,     10,    default
    animation = windows,       1,     7,     easeOutQuint, popin 80%
    animation = windowsIn,     1,     7,     easeOutQuint, popin 80%
    animation = windowsOut,    1,     7,     easeInOutCubic, popin 80%
    animation = fadeIn,        1,     7,     default
    animation = fadeOut,       1,     7,     default
    animation = workspaces,    1,     6,     default
}

# Dwindle 布局设置
dwindle {
    pseudotile = true       # 伪平铺模式开关
    preserve_split = true   # 保持窗口分割比例
}

# Master 布局设置
master {
    new_status = master
}

# 其他杂项
misc {
    force_default_wallpaper = -1 # -1表示启用随机的 Hyprland 动漫壁纸
    disable_hyprland_logo = false # 是否禁用启动时的 Hyprland Logo
}


#############
### 输入设备 ###
#############

input {
    kb_layout = us          # 键盘布局
    kb_variant =
    kb_model =
    kb_options =
    kb_rules =

    follow_mouse = 1        # 鼠标指针切换窗口焦点的方式
    sensitivity = 0         # 鼠标灵敏度 (-1.0 到 1.0, 0 为不修改)

    touchpad {
        natural_scroll = false # 是否开启自然滚动 (触摸板)
    }
}

# 新的手势语法
gestures {
    workspace_swipe = on    # 开启工作区滑动切换
}

# 针对特定设备的配置示例
device {
    name = epic-mouse-v1
    sensitivity = -0.5
}


###################
### 快捷键绑定 ###
###################

$mainMod = SUPER # 设置 Super 键 (Win键) 为主修饰键

# 您的个性化及优化后的快捷键
bind = $mainMod, R, exec, $terminal        # Super + R: 打开终端
bind = $mainMod, Q, killactive,            # Super + Q: 关闭当前活跃窗口
bind = $mainMod, E, exec, $fileManager     # Super + E: 打开文件管理器
bind = $mainMod, P, exec, $menu            # Super + P: 打开程序启动器
bind = $mainMod, SPACE, togglefloating,    # Super + Space: 切换窗口浮动状态
bind = $mainMod, F, fullscreen, 0          # Super + F: 切换窗口全屏

# 您的个性化剪贴板历史快捷键
bind = $mainMod, V, exec, cliphist list | wofi -dmenu | cliphist decode | wl-copy

# Dwindle 布局专用快捷键
bind = $mainMod, J, togglesplit,           # Super + J: 切换伪平铺模式下的分割方向

# 移动焦点
bind = $mainMod, left, movefocus, l
bind = $mainMod, right, movefocus, r
bind = $mainMod, up, movefocus, u
bind = $mainMod, down, movefocus, d

# 切换工作区
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10 # 将 Super + 0 映射到第10个工作区，比映射到0更符合直觉

# 移动当前窗口到指定工作区
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10

# 特殊工作区 (用作临时便签或"暂存区")
bind = $mainMod, S, togglespecialworkspace, magic
bind = $mainMod SHIFT, S, movetoworkspace, special:magic

# 使用鼠标滚轮切换工作区
bind = $mainMod, mouse_down, workspace, e+1
bind = $mainMod, mouse_up, workspace, e-1

# 使用 Super + 鼠标左/右键拖动/调整窗口大小
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow

# 退出 Hyprland 会话
bind = $mainMod, M, exec, hyprctl dispatch exit

# 多媒体按键 (音量, 亮度, 播放控制)
bindel = ,XF86AudioRaiseVolume, exec, wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+
bindel = ,XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindel = ,XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindel = ,XF86AudioMicMute, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindel = ,XF86MonBrightnessUp, exec, brightnessctl s 5%+
bindel = ,XF86MonBrightnessDown, exec, brightnessctl s 5%-
bindl = , XF86AudioNext, exec, playerctl next
bindl = , XF86AudioPlay, exec, playerctl play-pause
bindl = , XF86AudioPrev, exec, playerctl previous


##############################
### 窗口与工作区规则 ###
##############################
# 使用全新、更清晰的块状语法来定义规则

# 窗口规则: 抑制所有应用发来的最大化请求 (让 Hyprland 自己来管理窗口大小)
windowrule {
    name = suppress-maximize-events
    match:class = .*
    suppress_event = maximize
}

# 窗口规则: 修复部分 XWayland 应用 (如一些 Java 程序) 的拖动问题
windowrule {
    name = fix-xwayland-drags
    match:class = ^$
    match:title = ^$
    match:xwayland = true
    match:float = true
    match:fullscreen = false
    match:pin = false
    no_focus = true
}

# 更多规则示例:
# 让文件管理器默认以浮动窗口形式打开
# windowrulev2 = float, class:^(thunar|dolphin)$

# 工作区规则示例:
# 将工作区1绑定到名为 DP-1 的显示器上，并设为默认
# workspace = 1, monitor:DP-1, default:true
